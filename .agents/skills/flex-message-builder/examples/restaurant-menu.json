        {
          "type": "button",
          "style": "link",
          "height": "sm",
          "action": { "type": "uri", "label": "WEBSITE", "uri": "https://example.com/cafe" }
        },
        { "type": "box", "layout": "vertical", "contents": [], "margin": "sm" }
      ]
